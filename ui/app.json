{
  "expo": {
    "name": "pool-finder-app",
    "slug": "pool-finder-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon.svg",
      "bundler": "metro",
      "output": "single",
      "name": "Pool Finder",
      "shortName": "Pool Finder",
      "description": "Find lap swimming pools near you",
      "backgroundColor": "#0a0d12",
      "themeColor": "#5DCAA5",
      "display": "standalone",
      "orientation": "portrait",
      "scope": "/",
      "startUrl": "/"
    }
  }
}
